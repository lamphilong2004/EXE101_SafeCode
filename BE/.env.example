# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://localhost:27017/safecode

# JWT
JWT_SECRET=replace_me_with_long_random_secret
JWT_EXPIRES_IN=7d

# S3
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=replace_me
AWS_SECRET_ACCESS_KEY=replace_me
S3_BUCKET_ENCRYPTED=replace_me_bucket
S3_BUCKET_BUILDS=replace_me_bucket

# Crypto (32 bytes base64)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_KEY_B64=replace_me_32bytes_base64

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Public URL for webhook success/cancel defaults (optional)
APP_BASE_URL=http://localhost:5173
